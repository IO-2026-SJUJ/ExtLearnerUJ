# Skopiuj ten plik jako .env i uzupełnij właściwymi wartościami.
# Plik .env NIE może być commitowany do repozytorium.

# Django
DJANGO_SECRET_KEY=wygeneruj-wlasny-klucz-np-przez-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Cookie — w produkcji ustaw SECURE_COOKIES=True (tylko HTTPS)
SECURE_COOKIES=False

# Email — lokalnie zostawiamy locmem (maile w pamięci, dostępne w testach).
# W produkcji zmień na SMTP.
EMAIL_BACKEND=django.core.mail.backends.locmem.EmailBackend
EMAIL_HOST_USER=test@extlearner.uj.edu.pl

# Baza — w Sprincie 1 SQLite wystarcza.
# Od Sprintu 2 planowany Postgres (Supabase, region EU — wymóg RODO O-01).
DATABASE_URL=sqlite:///db.sqlite3
